---
import BlogLayout from '../../layouts/BlogLayout.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

const allPosts = (await getCollection('blog'))
  .filter(p => !p.data.draft && p.id !== post.id)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const relatedPosts = allPosts
  .filter(p => p.data.tags.some(t => post.data.tags.includes(t)))
  .slice(0, 2);

const formattedDate = post.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BlogLayout title={post.data.title} description={post.data.description} image={post.data.image}>

  <div class="max-w-content mx-auto px-6">
    <!-- Back link -->
    <a
      href="/blog"
      class="inline-flex items-center gap-2 text-wr-muted text-small font-medium hover:text-wr-dark transition-colors mb-8 group"
    >
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 15.75L3 12m0 0l3.75-3.75M3 12h18" />
      </svg>
      Back to Blog
    </a>

    <div class="flex gap-16">
      <!-- Main Content -->
      <article class="flex-1 min-w-0 max-w-prose">
        <!-- Post Header -->
        <header class="mb-12">
          <div class="flex flex-wrap gap-2 mb-4">
            {post.data.tags.map(tag => (
              <span class="inline-block bg-wr-teal/15 text-wr-dark text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">
                {tag}
              </span>
            ))}
          </div>

          <h1 class="text-3xl md:text-h1 text-wr-dark mb-4 leading-tight">
            {post.data.title}
          </h1>

          <p class="text-body-lg text-wr-muted mb-6">
            {post.data.description}
          </p>

          <div class="flex items-center gap-4 text-small text-wr-muted">
            <span class="font-medium">{post.data.author}</span>
            <span class="w-1 h-1 bg-wr-muted/40 rounded-full"></span>
            <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
          </div>
        </header>

        <!-- Cover Image -->
        {post.data.image && (
          <div class="mb-12 -mx-4 md:mx-0">
            <img
              src={post.data.image}
              alt={post.data.title}
              class="w-full rounded-2xl"
            />
          </div>
        )}

        <!-- Article Content -->
        <div class="prose">
          <Content />
        </div>

        <!-- Gradient Divider -->
        <div class="h-[2px] bg-gradient-to-r from-wr-teal via-wr-pink to-wr-yellow rounded-full my-16"></div>

        <!-- Author Card -->
        <div class="bg-wr-light rounded-2xl p-8 mb-16">
          <div class="flex items-start gap-5">
            <div class="w-14 h-14 rounded-full bg-wr-teal/20 flex items-center justify-center shrink-0">
              <span class="text-wr-dark font-bold text-lg">WR</span>
            </div>
            <div>
              <p class="font-medium text-wr-dark mb-1">{post.data.author}</p>
              <p class="text-wr-muted text-body">
                We Recruit IT connects US companies with top engineering talent across Latin America through staff augmentation and IT recruiting.
              </p>
            </div>
          </div>
        </div>
      </article>

      <!-- Table of Contents Sidebar -->
      <div class="w-64 shrink-0">
        <TableOfContents headings={headings} />
      </div>
    </div>

    <!-- Related Posts -->
    {relatedPosts.length > 0 && (
      <section class="mt-8 pb-16">
        <h2 class="text-h2 text-wr-dark mb-8 text-2xl md:text-h2">Related articles</h2>
        <div class="grid md:grid-cols-2 gap-8">
          {relatedPosts.map(related => (
            <PostCard
              title={related.data.title}
              description={related.data.description}
              date={related.data.date}
              tags={related.data.tags}
              slug={related.id}
              image={related.data.image}
            />
          ))}
        </div>
      </section>
    )}
  </div>

</BlogLayout>
