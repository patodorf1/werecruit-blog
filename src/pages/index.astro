---
import BlogLayout from '../layouts/BlogLayout.astro';
---

<BlogLayout title="IT Recruiting & Staff Augmentation in Latin America" description="We Recruit IT connects top Latin American tech talent with global companies. Build your remote team today.">

  <!-- Hero -->
  <section class="max-w-[1200px] mx-auto px-10 md:px-20 pt-6 pb-6 md:pt-10 md:pb-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-10 items-center">
      <div class="flex flex-col gap-8 items-center lg:items-start order-1">
        <div class="flex flex-col w-full max-w-[505px] gap-5">
          <h1 class="font-medium text-center lg:text-left text-3xl md:text-4xl lg:text-[48px] leading-[1.15] text-wr-dark">
            Unleash the potential of Latin American <span class="relative inline-block text-wr-dark"><span class="relative z-10">Tech talent</span><span class="absolute inset-0 bg-[#CAF7F8] rounded-[10px] -z-10"></span></span>
          </h1>
          <p class="text-base text-wr-dark text-center lg:text-left leading-[30px]">
            Connect with thoroughly vetted Latin American tech professionals who fit your technical needs and team culture!
          </p>
        </div>
        <div class="flex flex-wrap gap-4 justify-center lg:justify-start">
          <a
            href="https://zcal.co/t/wri/i-30min"
            class="inline-flex items-center justify-center px-7 py-5 bg-wr-dark text-white font-semibold text-base rounded-[16px] hover:bg-wr-dark/90 transition-colors"
            target="_blank"
            rel="noopener noreferrer"
          >
            Get started
          </a>
        </div>
      </div>
      <div class="order-2 flex justify-center">
        <img
          src="https://werecruit.it/wp-content/uploads/2025/09/img-5.png"
          alt="Latin American tech talent"
          class="w-full h-full object-contain object-center max-w-[420px]"
        />
      </div>
    </div>
  </section>

  <!-- Services -->
  <section class="max-w-[1200px] mx-auto px-6 py-16 md:py-24">
    <div class="flex flex-col gap-10 lg:gap-32">
      <div class="flex flex-col gap-4 w-full max-w-[990px] mx-auto text-center">
        <span class="block text-base text-wr-muted">Our services</span>
        <h2 class="font-medium text-2xl md:text-[32px] leading-tight tracking-[-0.02em] text-wr-dark">
          Discover how we can help you grow in one of the top global technology hubs: Latin America.
        </h2>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 md:gap-8 max-w-6xl mx-auto">
        <!-- Staff Augmentation Card -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end p-6 md:p-10 rounded-[20px] bg-[#FFE9EE] transition-transform duration-300 hover:-translate-y-1">
          <div class="flex-1 mb-6 md:mb-0 md:mr-8">
            <h3 class="font-medium text-xl md:text-2xl leading-none tracking-[-0.04em] text-wr-dark mb-4">
              Staff augmentation
            </h3>
            <p class="font-normal text-base leading-normal text-wr-dark">
              Boost your projects with top developers from Latin America. We handle payroll, hardware, onboarding, and local support so your team can focus entirely on delivery and growth.
            </p>
          </div>
          <div class="flex-shrink-0">
            <a
              href="https://werecruit.it/staff-augmentation/"
              class="flex items-center justify-center w-[45px] h-[45px] sm:w-[65px] sm:h-[65px] rounded-[5px] bg-white border border-gray-200 hover:scale-105 transition-transform"
              aria-label="View Staff Augmentation"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="22" viewBox="0 0 34 31" fill="none">
                <path d="M0.149056 15.3099H31.4227" stroke="#132738" />
                <path d="M17.2751 1.1626L31.7951 15.6825L18.0198 29.4578" stroke="#132738" />
              </svg>
            </a>
          </div>
        </div>
        <!-- Direct Hiring Card -->
        <div class="flex flex-col md:flex-row justify-between items-start md:items-end p-6 md:p-10 rounded-[20px] bg-[#FFF8D6] transition-transform duration-300 hover:-translate-y-1">
          <div class="flex-1 mb-6 md:mb-0 md:mr-8">
            <h3 class="font-medium text-xl md:text-2xl leading-none tracking-[-0.04em] text-wr-dark mb-4">
              Direct Hiring
            </h3>
            <p class="font-normal text-base leading-normal text-wr-dark">
              Success-based model: you only pay upon hire. Backed by a solid 1-year guarantee, ensuring stability, continuity, and the long-term strength of your team.
            </p>
          </div>
          <div class="flex-shrink-0">
            <a
              href="https://werecruit.it/it-recruiting/"
              class="flex items-center justify-center w-[45px] h-[45px] sm:w-[65px] sm:h-[65px] rounded-[5px] bg-white border border-gray-200 hover:scale-105 transition-transform"
              aria-label="View IT Recruiting"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="22" viewBox="0 0 34 31" fill="none">
                <path d="M0.149056 15.3099H31.4227" stroke="#132738" />
                <path d="M17.2751 1.1626L31.7951 15.6825L18.0198 29.4578" stroke="#132738" />
              </svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trusted By Banner -->
  <section class="w-full bg-wr-dark py-16 md:py-20 -mx-6 px-6" style="margin-left: calc(-50vw + 50%); margin-right: calc(-50vw + 50%); width: 100vw;">
    <div class="max-w-[1200px] mx-auto text-center">
