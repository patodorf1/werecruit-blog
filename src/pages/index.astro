</BlogLayout>

<style>
  @keyframes scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-33.33%); }
  }
  .animate-scroll {
    animation: scroll 40s linear infinite;
  }
  .animate-scroll-slow {
    animation: scroll 30s linear infinite;
  }
</style>
