  <!-- Contact Section -->
  <section class="max-w-[1200px] mx-auto px-6 py-16 md:py-24 text-center">
    <div class="max-w-2xl mx-auto flex flex-col items-center gap-6">
      <span class="block text-base text-wr-muted">Ready to build your team?</span>
      <h2 class="font-medium text-3xl md:text-[42px] leading-tight tracking-[-0.02em] text-wr-dark">
        Let's connect and find the perfect fit for your company.
      </h2>
      <a
        href="https://zcal.co/t/wri/i-30min"
        class="inline-flex items-center justify-center px-8 py-6 bg-wr-dark text-white font-semibold text-base rounded-[20px] hover:bg-wr-dark/90 transition-colors mt-4"
