          <img src="https://werecruit.it/wp-content/uploads/2025/08/Rectangle-51.png" alt="" class="w-16 h-16 md:w-[72px] md:h-[72px] object-cover rounded-xl" />
          <div class="w-16 h-16 md:w-[72px] md:h-[72px] rounded-xl flex items-center justify-center bg-[#FD7B99] flex-shrink-0">
