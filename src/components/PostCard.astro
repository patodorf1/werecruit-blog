---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
  image?: string;
}

const { title, description, date, tags, slug, image } = Astro.props;

const readTime = Math.max(3, Math.ceil(description.length / 200)) + ' min read';
const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="group">
  <a href={`/${slug}`} class="block">
    <div class="bg-white rounded-2xl overflow-hidden border border-wr-dark/5 transition-all duration-300 group-hover:shadow-lg group-hover:shadow-wr-teal/10 group-hover:-translate-y-1 group-hover:border-wr-teal/30">
      <!-- Cover Image -->
      {image ? (
        <div class="aspect-[16/9] overflow-hidden bg-wr-light">
          <img
            src={image}
            alt={title}
            class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
            loading="lazy"
          />
        </div>
      ) : (
        <div class="aspect-[16/9] bg-gradient-to-br from-wr-light via-wr-teal/10 to-wr-pink/10 flex items-center justify-center">
          <div class="w-16 h-16 rounded-full bg-wr-teal/20 flex items-center justify-center">
            <svg class="w-8 h-8 text-wr-teal" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25" />
            </svg>
          </div>
        </div>
      )}

      <div class="p-6">
        <!-- Tags -->
        <div class="flex flex-wrap gap-2 mb-3">
          {tags.slice(0, 3).map(tag => (
            <span class="inline-block bg-wr-teal/15 text-wr-dark text-xs font-bold px-2.5 py-1 rounded-full uppercase tracking-wide">
              {tag}
            </span>
          ))}
        </div>

        <!-- Title -->
        <h3 class="text-h3 text-wr-dark mb-2 group-hover:text-wr-teal-deep transition-colors duration-200 text-xl md:text-2xl font-medium leading-tight">
          {title}
        </h3>

        <!-- Excerpt -->
        <p class="text-wr-muted text-body mb-4 line-clamp-2">
          {description}
        </p>

        <!-- Meta -->
        <div class="flex items-center justify-between text-small text-wr-muted">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span>{readTime}</span>
        </div>

        <!-- Read more indicator -->
        <div class="mt-4 pt-4 border-t border-wr-dark/5">
          <span class="text-wr-dark font-bold text-small flex items-center gap-1.5 group-hover:text-wr-teal-deep group-hover:gap-2.5 transition-all duration-200">
            Read more
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
            </svg>
          </span>
        </div>
      </div>
    </div>
  </a>
</article>
