---
const navLinks = [
  { label: 'Staff Augmentation', href: 'https://werecruit.it/staff-augmentation' },
  { label: 'IT Recruiting', href: 'https://werecruit.it/it-recruiting' },
  { label: 'Candidates', href: 'https://werecruit.it/candidates' },
  { label: 'Blog', href: '/blog' },
];
---

<footer class="bg-wr-teal relative overflow-hidden mt-24">
  <!-- Dot pattern overlay -->
  <div class="absolute inset-0 bg-dot-pattern opacity-[0.08] pointer-events-none"></div>

  <div class="relative max-w-content mx-auto px-6 py-16">
    <div class="flex flex-col md:flex-row items-start justify-between gap-12">
      <!-- Logo -->
      <div class="shrink-0">
        <a href="https://werecruit.it" class="text-wr-dark font-medium text-2xl tracking-tight">
          wr<span class="inline-flex items-center justify-center w-6 h-6 bg-wr-dark text-white text-xs font-bold rounded ml-0.5 relative -top-[1px]">.it</span>
        </a>
      </div>

      <!-- Nav Links -->
      <nav class="flex flex-col gap-4">
        {navLinks.map(link => (
          <a
            href={link.href}
            class="text-wr-dark font-medium text-lg hover:underline underline-offset-4 transition-all"
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- Contact CTA -->
      <div class="text-right">
        <a
          href="https://werecruit.it/#contact"
          class="text-wr-dark font-medium text-[42px] leading-tight hover:underline underline-offset-8 decoration-2 transition-all"
        >
          Contact Us!
        </a>
      </div>
    </div>

    <!-- Bottom row -->
    <div class="flex flex-col md:flex-row items-center justify-between mt-16 pt-8 border-t border-wr-dark/10 gap-4">
      <p class="text-wr-dark/70 text-small">&copy; {new Date().getFullYear()}. All rights reserved. We Recruit IT</p>
      <div class="flex items-center gap-2 text-small text-wr-dark/70">
        <a href="https://werecruit.it" class="hover:text-wr-dark transition-colors font-medium">ENG</a>
        <span>-</span>
        <a href="https://werecruit.it/es" class="hover:text-wr-dark transition-colors font-medium">ESP</a>
      </div>
    </div>
  </div>
</footer>
